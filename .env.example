# ═══════════════════════════════════════════════════════════════════════════
# Feltabout — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# For Docker: docker compose reads from this file automatically
# For local dev: source these or use a tool like direnv
# ═══════════════════════════════════════════════════════════════════════════

# ─── Database ──────────────────────────────────────────────────────────────
POSTGRES_DB=feltabout
POSTGRES_USER=feltabout
POSTGRES_PASSWORD=change-me-in-prod

# Connection string for the API service (uses Docker network hostname)
DATABASE_URL=postgresql+asyncpg://feltabout:${POSTGRES_PASSWORD}@postgres:5432/feltabout

# ─── Authentication ─────────────────────────────────────────────────────────
# Set USE_AUTH=true in production
USE_AUTH=false

# Generate a secure random string for JWT signing:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=dev-secret-change-in-production

# ─── AI Configuration ───────────────────────────────────────────────────────
# Leave empty to use local fallback (limited functionality)
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:8082

# ─── Frontend (for reference, set via NEXT_PUBLIC_ prefix) ──────────────────
# Frontend reads NEXT_PUBLIC_API_URL from its own .env.local or Docker env
# Default for Docker: http://api:8000 (Docker internal network)
NEXT_PUBLIC_API_URL=http://api:8000

# ─── MVP 2 Bridge (must be false for MVP 1) ─────────────────────────────────
ENABLE_MVP2_BACKEND_BRIDGE=false

# ─── Optional: Field Encryption ─────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required in production for encrypting sensitive reflection data
ENCRYPTION_KEY=

# ═══════════════════════════════════════════════════════════════════════════
# NOT INCLUDED IN MVP 1
# ═══════════════════════════════════════════════════════════════════════════
# The following are NOT wired in MVP 1:
# - LIVEKIT_URL, LIVEKIT_API_KEY, LIVEKIT_API_SECRET (voice sessions)
# - SMTP_* (email sending for magic links)
# - REDIS_* (caching/sessions)
# - SENTRY_* (error tracking)
# ═══════════════════════════════════════════════════════════════════════════