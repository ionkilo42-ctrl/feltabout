# ─────────────────────────────────────────────────────────────────────────────
# RelateFX Backend — Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to version control
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
USE_AUTH=false
USE_POSTGRES=false
SESSION_TTL_HOURS=2
ALLOWED_ORIGINS=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────────────
# Local (in-memory fallback when USE_POSTGRES=false — no config needed)
# Production:
# DATABASE_URL=postgresql+asyncpg://relatefx:YOUR_PASSWORD@localhost:5432/relatefx

# ── LLM ──────────────────────────────────────────────────────────────────────
# Get your key at https://platform.minimax.io/
MINIMAX_API_KEY=your_minimax_api_key_here

# ── Auth (optional) ──────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-local-admin-password
ADMIN_NAME=Admin
REVIEW_SECRET=replace-with-another-long-random-string  # for human reviewer dashboard

# ── Voice / WebRTC ───────────────────────────────────────────────────────────
# LiveKit Cloud: https://cloud.livekit.io
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Deepgram: https://console.deepgram.com/
DEEPGRAM_API_KEY=your_deepgram_api_key

# ElevenLabs: https://elevenlabs.io/
ELEVENLABS_API_KEY=your_elevenlabs_api_key
