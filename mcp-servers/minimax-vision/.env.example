# MiniMax Vision MCP Server Configuration

# Required: Your MiniMax API key
MINIMAX_API_KEY=

# API base URL (default: https://api.minimax.io/v1)
MINIMAX_BASE_URL=https://api.minimax.io/v1

# Model to use (default: MiniMax-M2.7)
# Note: MiniMax-M2.7 supports vision. MiniMax-VL-01 and MiniMax-VL-16K are not available for this token plan.
MINIMAX_MODEL=MiniMax-M2.7