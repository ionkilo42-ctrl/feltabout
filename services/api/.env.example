# feltabout API Configuration

# Database
DATABASE_URL=sqlite+aiosqlite:///./feltabout.db

# Authentication (set to 'true' in production)
USE_AUTH=false

# AI Provider: 'minimax' or 'openai'
LLM_PROVIDER=minimax

# MiniMax LLM Configuration (production)
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2.7

# OpenAI Fallback (leave empty to use MiniMax only)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=your_encryption_key_here

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8081,http://localhost:8082

# Frontend URL (for magic link generation)
FRONTEND_URL=http://localhost:3000