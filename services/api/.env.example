DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/feltabout
USE_AUTH=false
# Future: AUTH_PROVIDER=clerk|supabase
# Future: CLERK_PUBLISHABLE_KEY=...
# Future: SUPABASE_URL=...
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:8082

# ─── Field-level encryption ────────────────────────────────────────────────────
# Required in production. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# In development, a temporary key is used (data becomes unreadable after restart).
ENCRYPTION_KEY=
