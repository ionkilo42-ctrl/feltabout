# ═══════════════════════════════════════════════════════════════════════════
# Feltabout — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Local Docker development intentionally uses friendly defaults.
# Deployed environments should set APP_ENV=production, USE_AUTH=true,
# strong secrets, explicit origins, and non-placeholder database credentials.
# ═══════════════════════════════════════════════════════════════════════════

# ─── Runtime Mode ──────────────────────────────────────────────────────────
APP_ENV=development

# ─── Database ──────────────────────────────────────────────────────────────
POSTGRES_DB=feltabout
POSTGRES_USER=feltabout
POSTGRES_PASSWORD=change-me-in-prod

# Connection string for the API service (uses Docker network hostname)
DATABASE_URL=postgresql+asyncpg://feltabout:${POSTGRES_PASSWORD}@postgres:5432/feltabout

# ─── Authentication ─────────────────────────────────────────────────────────
# Local dev can keep this false. Set true for production-like auth.
USE_AUTH=false

# Generate a secure random string for JWT signing:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Required when USE_AUTH=true.
JWT_SECRET=dev-secret-change-in-production

# ─── Email / Magic Links ────────────────────────────────────────────────────
# Email delivery is not implemented in MVP 1. Keep false unless a provider
# is intentionally wired. Magic links may log to the server console in dev.
EMAIL_ENABLED=false
FRONTEND_URL=http://localhost:3000

# ─── AI Configuration ───────────────────────────────────────────────────────
# Active default: MiniMax. Leave keys empty to use local fallback generation.
AI_PROVIDER=minimax
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2.7
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use explicit deployed origins before launch.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:8082

# ─── Frontend ───────────────────────────────────────────────────────────────
# Frontend reads NEXT_PUBLIC_API_URL from its own env or Docker env.
# Default for Docker: http://api:8000 (Docker internal network)
NEXT_PUBLIC_API_URL=http://api:8000

# ─── MVP 2 Bridge (must be false for MVP 1) ─────────────────────────────────
ENABLE_MVP2_BACKEND_BRIDGE=false

# ─── Optional: Field Encryption ─────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required before storing real sensitive user reflection data.
ENCRYPTION_KEY=

# ═══════════════════════════════════════════════════════════════════════════
# NOT INCLUDED IN MVP 1
# ═══════════════════════════════════════════════════════════════════════════
# The following are NOT wired in MVP 1:
# - LIVEKIT_URL, LIVEKIT_API_KEY, LIVEKIT_API_SECRET (voice sessions)
# - SMTP_* (production email delivery)
# - REDIS_* (caching/sessions)
# - SENTRY_* (error tracking)
# ═══════════════════════════════════════════════════════════════════════════
